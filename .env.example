# orcai-mcp environment variables
# Copy to .env and fill in values

# Server
PORT=8100

# Authentication (set MCP_AUTH_DISABLED=true for local dev)
MCP_AUTH_TOKEN=your-secret-token-here
MCP_AUTH_DISABLED=true

# IDE target: "claude" or "cursor"
IDE_TARGET=claude

# Concurrency
MAX_CONCURRENT_AGENTS=3
TASK_QUEUE_SIZE=20

# Anthropic API key (required for api runner)
ANTHROPIC_API_KEY=sk-ant-...

# Volume paths (default to Docker volume mounts)
DATA_DIR=/data
# Path to .claude/ directory — the shared source of truth for agents (*.md) and skills (*/SKILL.md).
# Agents here are discoverable by Claude Code, Cursor CLI, and orcai-mcp simultaneously.
CLAUDE_DIR=/project/.claude
# Exposed to CLI agents as $PROJECT_DIR — the project root Claude Code opens.
PROJECT_DIR=/project

# Allowed Host headers for DNS rebinding protection (comma-separated).
# Required when running behind a reverse proxy — set to your public domain.
# Leave empty to disable the check (only safe when the server is not publicly reachable).
# Example: MCP_ALLOWED_HOSTS=mcp.yourserver.com
MCP_ALLOWED_HOSTS=
